# ── PRUDEV II Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Django
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True

# ── Email (Zoho Mail SMTP) ──────────────────────────────────────────────────
#
# HOW TO SET UP:
#   1. Sign in to https://mail.zoho.com with the sending account
#      (default: noreply@smartvet.africa)
#   2. Go to Settings → Security → App Passwords → Generate new password
#      (name it something like "PRUDEV II Backend")
#   3. Paste that app password as ZOHO_APP_PASSWORD below
#
ZOHO_HOST_USER=noreply@smartvet.africa
ZOHO_APP_PASSWORD=your-zoho-app-password
EMAIL_REPLY_TO=richard.obuku@gopa.eu

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem().decode()); print(v.public_key.public_bytes_raw().hex())"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=richard.obuku@gopa.eu

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use the default SQLite file (db.sqlite3)
DATABASE_URL=
