# ── PRUDEV II Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Django
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True

# ── Email (Microsoft Office 365 / Outlook) ───────────────────────────────────
# SMTP server: smtp.office365.com  port: 587  TLS: STARTTLS
#
# EMAIL_HOST_PASSWORD must be set for mail to actually deliver.
# Two options:
#   1. Your normal Microsoft 365 password (if your IT admin has enabled SMTP AUTH
#      for your mailbox — check via Microsoft 365 admin centre or run:
#      Get-CASMailbox richard.obuku@gopa.eu | Select SmtpClientAuthenticationDisabled)
#   2. An App Password (if MFA is enabled on your account):
#      Microsoft account → Security → Advanced security options → App passwords
#
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=richard.obuku@gopa.eu
EMAIL_HOST_PASSWORD=your-outlook-password-or-app-password
DEFAULT_FROM_EMAIL=PRUDEV II Programme <richard.obuku@gopa.eu>

# Set to True to send real emails even in DEBUG mode (useful for local testing)
EMAIL_ALWAYS_SMTP=False

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem().decode()); print(v.public_key.public_bytes_raw().hex())"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=richard.obuku@gopa.eu

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use the default SQLite file (db.sqlite3)
DATABASE_URL=
